  (Create workout template)       as F1
  (Edit workout template)         as F2
  (Delete workout template)       as F3
  (View workout library)          as F4
  (Search / filter library)       as F5
  (View workout template details) as F6
  (Mark workout as favourite)     as F7
  (Tag workout template)          as F8
}

COA --> F1
COA --> F2
COA --> F3
COA --> F4
COA --> F5
COA --> F6
COA --> F7
COA --> F8

' ═════════════════════════════════════════════════════════════════════════════
' 7. SEASON PLANNING
' ═════════════════════════════════════════════════════════════════════════════
rectangle "7. Season Planning" {
  (Define goal races)         as G1
  (Define training constraints) as G2
  (Preview AI season plan)    as G3
  (Save season plan)          as G4
  (Edit season plan)          as G5
  (Delete season plan)        as G6
  (Apply season plan)         as G7
  (View current season plan)  as G8

  G3 ..> G1 : <<include>>
  G3 ..> G2 : <<include>>
  G7 ..> G4 : <<include>>
}

COA --> G1
COA --> G2
COA --> G3
COA --> G4
COA --> G5
COA --> G6
COA --> G7
ATH --> G8

