@startuml Training Plans – Full Use Case Diagram

skinparam packageStyle rectangle
skinparam usecaseFontSize 11
skinparam actorStyle awesome
skinparam packageBorderColor #444444
skinparam usecaseBorderColor #666666
skinparam defaultFontSize 11
skinparam wrapWidth 160
skinparam maxMessageSize 160

scale max 4096 width
scale max 4096 height

' ─── ACTORS ──────────────────────────────────────────────────────────────────
actor Athlete         as ATH
actor Coach           as COA
actor Admin           as ADM
actor "External\nProvider" as EXT  <<system>>
actor "Email\nSystem"      as MAIL <<system>>

' Coach is a specialisation of Athlete — inherits all Athlete use cases
COA --|> ATH

' ═════════════════════════════════════════════════════════════════════════════
' 1. AUTHENTICATION
' ═════════════════════════════════════════════════════════════════════════════
rectangle "1. Authentication" {
  (Register account)         as A1
  (Log in)                   as A2
  (Log out)                  as A3
  (Refresh access token)     as A4
  (Verify email)             as A5
  (Request password reset)   as A6
  (Reset password)           as A7
  (Change password)          as A8

  A1 ..> A5 : <<include>>
}

ATH  --> A1
ATH  --> A2
ATH  --> A3
ATH  --> A4
ATH  --> A5
ATH  --> A6
ATH  --> A7
ATH  --> A8
ADM  --> A2
ADM  --> A3
ADM  --> A4
ADM  --> A6
ADM  --> A7
ADM  --> A8
MAIL --> A5
MAIL --> A6

' ═════════════════════════════════════════════════════════════════════════════
' 2. USER & PROFILE MANAGEMENT
' ═════════════════════════════════════════════════════════════════════════════
rectangle "2. User & Profile Management" {
  (View own profile)           as B1
  (Edit own profile)           as B2
  (Configure preferences)      as B3
  (Log metric)                 as B4
  (View metric history)        as B5
  (View athlete profile)       as B6
  (Edit athlete profile)       as B7
  (View athlete permissions)   as B8
  (Set athlete permissions)    as B9
  (Invite athlete by link)     as B10
  (Invite athlete by email)    as B11
}

ATH --> B1
ATH --> B2
ATH --> B3
ATH --> B4
ATH --> B5
ATH --> B8
COA --> B6
COA --> B7
COA --> B9
COA --> B10
COA --> B11

' ═════════════════════════════════════════════════════════════════════════════
' 3. ORGANIZATION MANAGEMENT
' ═════════════════════════════════════════════════════════════════════════════
rectangle "3. Organization Management" {
  (Create organization)           as C1
  (Discover organizations)        as C2
  (Request to join organization)  as C3
  (Accept / decline invitation)   as C4
  (Leave organization)            as C5
  (Approve pending athlete)       as C6
  (Reject pending athlete)        as C7
  (View organization members)     as C8
  (Remove member)                 as C9
  (Post group message)            as C10
  (View group messages)           as C11
  (Send direct message)           as C12
  (View direct messages)          as C13
}

ATH --> C2
ATH --> C3
ATH --> C4
ATH --> C5
ATH --> C10
ATH --> C11
ATH --> C12
ATH --> C13
COA --> C1
COA --> C6
COA --> C7
COA --> C8
COA --> C9

' ═════════════════════════════════════════════════════════════════════════════
' 4. ACTIVITY MANAGEMENT
' ═════════════════════════════════════════════════════════════════════════════
rectangle "4. Activity Management" {
  (Upload activity file)                as D1
  (Create activity manually)            as D2
  (View activity list)                  as D3
  (View activity details)               as D4
  (Edit activity)                       as D5
  (Delete activity)                     as D6
  (Re-parse activity file)              as D7
  (View duplicate activities)           as D8
  (Mark activity as primary duplicate)  as D9
  (View personal records)               as D10
  (View best efforts)                   as D11
  (View execution score)                as D12
  (View training status)                as D13

  note right of D6
    Athlete requires
    coach permission
  end note
}

ATH  --> D1
ATH  --> D2
ATH  --> D3
ATH  --> D4
ATH  --> D5
ATH  --> D6
ATH  --> D7
ATH  --> D8
ATH  --> D9
ATH  --> D10
ATH  --> D11
ATH  --> D12
ATH  --> D13
EXT  --> D1

' ═════════════════════════════════════════════════════════════════════════════
' 5. TRAINING CALENDAR
' ═════════════════════════════════════════════════════════════════════════════
rectangle "5. Training Calendar" {
  (View own training calendar)  as E1
  (View athlete's calendar)     as E2
  (Create planned workout)      as E3
  (Edit planned workout)        as E4
  (Delete planned workout)      as E5
  (Copy planned workout)        as E6
  (Download workout as ICS)     as E7
  (View compliance status)      as E8
  (View recent coach workouts)  as E9
  (Create day note)             as E10
  (View day notes)              as E11
  (Delete day note)             as E12

  note right of E4
    Athlete requires
    coach permission
  end note
  note right of E5
    Athlete requires
    coach permission
  end note
}

ATH --> E1
ATH --> E4
ATH --> E5
ATH --> E7
ATH --> E8
ATH --> E9
ATH --> E10
ATH --> E11
ATH --> E12
COA --> E2
COA --> E3
COA --> E6

