# Copy this file to .env and fill values

SECRET_KEY=
INTEGRATIONS_TOKEN_ENCRYPTION_KEY=
AUTH_COOKIE_SECURE=false
EXPOSE_AUTH_DEBUG_LINKS=false

ENABLE_STRAVA_INTEGRATION=true
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/integrations/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Sync strategy
STRAVA_INITIAL_SYNC_MAX_ACTIVITIES=50
STRAVA_SYNC_MAX_ACTIVITIES=50
STRAVA_FULL_HISTORY_ENABLED=true
STRAVA_BACKFILL_BATCH_ACTIVITIES=100
STRAVA_BACKFILL_REQUEST_DELAY_SECONDS=2.0
