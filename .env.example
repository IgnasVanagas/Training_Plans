# Copy this file to .env and fill values

SECRET_KEY=
INTEGRATIONS_TOKEN_ENCRYPTION_KEY=
DATABASE_URL=
FRONTEND_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
EXPOSE_AUTH_DEBUG_LINKS=false
AUTO_SEED_DEMO=true

ENABLE_STRAVA_INTEGRATION=true
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/integrations/strava/callback
STRAVA_SCOPES=read,activity:read,activity:read_all
STRAVA_OAUTH_APPROVAL_PROMPT=auto
STRAVA_WEBHOOK_CALLBACK_URL=
STRAVA_WEBHOOK_VERIFY_TOKEN=
STRAVA_REPLACE_EXISTING_WEBHOOK_SUBSCRIPTION=false

# Frontend build/runtime
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT_MS=15000

# Sync strategy
STRAVA_INITIAL_SYNC_MAX_ACTIVITIES=50
STRAVA_SYNC_MAX_ACTIVITIES=50
STRAVA_FULL_HISTORY_ENABLED=true
STRAVA_BACKFILL_BATCH_ACTIVITIES=100
STRAVA_BACKFILL_REQUEST_DELAY_SECONDS=2.0
